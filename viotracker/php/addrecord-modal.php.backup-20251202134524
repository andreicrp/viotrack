<script>
function toggleDropdown(type) {
    const dd = document.getElementById(type + "Dropdown");
    const ds = document.getElementById(type + "SelectDisplay");
    ["student","minor","serious","major"].forEach(t => {
        if (t !== type) {
            const d = document.getElementById(t + "Dropdown");
            const s = document.getElementById(t + "SelectDisplay");
            if (d) d.classList.remove("show");
            if (s) s.classList.remove("active");
        }
    });
    if (dd.classList.contains("show")) {
        dd.classList.remove("show");
        ds.classList.remove("active");
    } else {
        dd.classList.add("show");
        ds.classList.add("active");
    }
}

function toggleSelection(type, idx, e) {
    e.stopPropagation();
    const cb = document.getElementById(type + "-" + idx);
    const opt = document.querySelector("#" + type + "Options .student-option[data-index=\"" + idx + "\"]");
    cb.checked = !cb.checked;
    if (cb.checked) opt.classList.add("selected");
    else opt.classList.remove("selected");
    updateSelectedDisplay(type);
    checkFormValidity();
}

function updateSelectedDisplay(type) {
    const cbs = document.querySelectorAll("#" + type + "Options .student-option-checkbox:checked");
    const cnt = cbs.length;
    const el = document.getElementById(type + "SelectDisplay");
    const cnt_el = document.getElementById(type + "SelectedCount");
    if (cnt === 0) {
        cnt_el.textContent = "Nothing selected";
        el.innerHTML = "<span class=\"student-placeholder\">Select " + (type === "student" ? "students" : type + " offenses") + "...</span>";
    } else {
        cnt_el.textContent = cnt + " selected";
        const names = Array.from(cbs).map(c => c.closest(".student-option").querySelector("label").textContent).join(", ");
        el.innerHTML = "<span class=\"student-selected-text\">" + names + "</span>";
    }
}

function searchItems(type, term) {
    term = term.toLowerCase();
    document.querySelectorAll("#" + type + "Options .student-option").forEach(opt => {
        opt.style.display = opt.textContent.toLowerCase().includes(term) ? "flex" : "none";
    });
}

function checkFormValidity() {
    const has_s = document.querySelectorAll("#studentOptions .student-option-checkbox:checked").length > 0;
    const has_v = (document.querySelectorAll("#minorOptions .student-option-checkbox:checked").length +
                   document.querySelectorAll("#seriousOptions .student-option-checkbox:checked").length +
                   document.querySelectorAll("#majorOptions .student-option-checkbox:checked").length) > 0;
    document.getElementById("addRecordBtn").disabled = !(has_s && has_v);
}

function openAddRecordModal() {
    document.getElementById("addRecordModal").classList.add("show");
    document.body.style.overflow = "hidden";
}

function closeAddRecordModal() {
    document.getElementById("addRecordModal").classList.remove("show");
    document.body.style.overflow = "";
}

document.addEventListener("DOMContentLoaded", function() {
    ["student","minor","serious","major"].forEach(t => updateSelectedDisplay(t));
    
    const frm = document.getElementById("addRecordForm");
    if (frm) {
        frm.addEventListener("submit", function(e) {
            e.preventDefault();
            
            const students = document.querySelectorAll("#studentOptions .student-option-checkbox:checked");
            const violations = document.querySelectorAll("[id$='Options'] .student-option-checkbox:checked:not(#studentOptions .student-option-checkbox)");
            
            if (students.length === 0 || violations.length === 0) {
                alert("Please select at least one student and violation");
                return;
            }
            
            const records = [];
            students.forEach(s => {
                violations.forEach(v => {
                    records.push({
                        sid: s.value,
                        vid: v.value,
                        lat: "14.6124466",
                        lng: "120.9879835",
                        date: new Date().toISOString().split("T")[0]
                    });
                });
            });
            
            // Try to save offline BEFORE attempting network
            fetch("check-connectivity.php", {method: "HEAD", cache: "no-store"})
                .then(r => {
                    console.log("ONLINE - submit normally");
                    // Online: would submit to server normally
                    alert("Online - normal submission");
                })
                .catch(err => {
                    console.log("OFFLINE - saving to localStorage");
                    records.forEach(r => {
                        let pending = JSON.parse(localStorage.getItem("pendingViolationRecords") || "[]");
                        pending.push(r);
                        localStorage.setItem("pendingViolationRecords", JSON.stringify(pending));
                    });
                    alert("✓ " + records.length + " violation(s) saved offline. Will sync when connected.");
                    closeAddRecordModal();
                });
        });
    }
});

document.addEventListener("click", function(e) {
    ["student","minor","serious","major"].forEach(t => {
        const dd = document.getElementById(t + "Dropdown");
        const ds = document.getElementById(t + "SelectDisplay");
        if (dd && ds && !dd.contains(e.target) && !ds.contains(e.target)) {
            dd.classList.remove("show");
            ds.classList.remove("active");
        }
    });
});

document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") {
        const m = document.getElementById("addRecordModal");
        if (m && m.classList.contains("show")) closeAddRecordModal();
    }
});
</script>
